<%# locals: (task:, compact: false) %>
<div class="task-card task-card--<%= task.source %> <%= task.card_height_class %> <%= 'task-card--completed' if task.completed? %>"
     id="task_<%= task.id %>"
     draggable="true"
     data-controller="task-card"
     data-task-card-id-value="<%= task.id %>"
     data-task-card-completed-value="<%= task.completed? %>"
     data-action="dragstart->sortable#dragstart dragend->sortable#dragend"
     style="<%= task.completed? ? "--stamp-rotation: #{task.stamp_rotation_degrees}deg" : '' %>">

  <div class="task-card__header">
    <% if task.completed? %>
      <span class="task-card__title"><%= task.title %></span>
    <% else %>
      <button class="task-card__complete-button"
              data-action="click->task-card#animateThenComplete"
              title="Mark done">
        <%= task.title %>
      </button>
    <% end %>
    <button class="size-badge"
            data-action="click->task-card#cycleSize"
            title="Click to change size">
      <%= task.size.first.upcase %>
    </button>
  </div>

  <% unless compact %>
    <% if task.description.present? %>
      <p class="task-card__project"><%= truncate(task.description, length: 80) %></p>
    <% end %>
  <% end %>

  <% if task.project_name.present? || task.planned_duration_minutes.present? %>
    <div class="task-card__meta">
      <% if task.project_name.present? %>
        <span class="task-card__project"><%= task.source == "local" ? "Personal" : task.source.capitalize %> &middot; <%= task.project_name %></span>
      <% end %>
      <% if task.planned_duration_minutes.present? %>
        <span class="task-card__duration"><%= task.planned_duration_minutes %>m</span>
      <% end %>
    </div>
  <% end %>

  <% if task.completed? %>
    <div class="task-card__stamp" data-task-card-target="stamp">
      <%= render "stamps/#{task.user.stamp_choice}" %>
    </div>
  <% end %>
</div>
