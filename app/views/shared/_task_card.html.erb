<%# locals: (task:, compact: false) %>
<div class="task-card task-card--<%= task.hey_app_url.present? ? 'hey' : task.source %> card--<%= task.size %> <%= 'task-card--completed' if task.completed? %>"
     id="task_<%= task.id %>"
     tabindex="0"
     draggable="true"
     data-controller="task-card"
     data-task-card-id-value="<%= task.id %>"
     data-task-card-completed-value="<%= task.completed? %>"
     data-hey-email-task="<%= task.hey_app_url.present? %>"
     data-action="click->task-card#openModal keydown->task-card#handleKeydown dragstart->sortable#dragstart dragend->sortable#dragend"
     style="<%= task.completed? ? "--stamp-rotation: #{task.stamp_rotation_degrees}deg" : '' %>">

  <button class="task-card__size-badge"
          data-action="click->task-card#cycleSize"
          title="Click to change size">
    <%= task.size.first.upcase %>
  </button>

  <div class="task-card__title"><%= task.title %></div>
  <% if task.timeboxed? && task.week_bucket != "sometime" %>
    <div class="task-card__dedicated"><%= TimelineLayout.format_duration_hm(task.planned_duration_minutes || 60) %> on timeline</div>
  <% end %>

  <div class="task-card__bottom">
    <% if task.completed? %>
      <button class="task-card__check task-card__check--done"
              data-action="click->task-card#animateThenComplete"
              title="Completed"
              aria-label="Completed">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <rect x="1" y="1" width="14" height="14" rx="3.5" fill="#16A34A"/>
          <polyline points="4.5,8.5 7,11 11.5,5.5" stroke="#fff" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        </svg>
      </button>
    <% else %>
      <button class="task-card__check"
              data-action="click->task-card#animateThenComplete"
              title="Mark done"
              aria-label="Mark done">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <rect x="1" y="1" width="14" height="14" rx="3.5" stroke="currentColor" stroke-width="1.25"/>
        </svg>
      </button>
    <% end %>

    <div class="task-card__obj-dot" aria-hidden="true"></div>

    <div class="task-card__project-label">
      <% if task.hey? || task.hey_app_url.present? %>
        HEY Email
      <% elsif task.project_name.present? %>
        <%= task.project_name %>
      <% end %>
    </div>
  </div>

  <% if task.completed? %>
    <div class="task-card__stamp" data-task-card-target="stamp">
      <%= render "stamps/#{task.user.stamp_choice}" %>
    </div>
  <% end %>
</div>
