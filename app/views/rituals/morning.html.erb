<% if @step == 1 %>
  <% content_for(:topbar) do %>
    <span class="topbar__title topbar__title--serif">Sunrise</span>
    <span class="topbar__sub topbar__sub--serif">A quiet look back</span>
  <% end %>
<% elsif @step == 2 %>
  <% content_for(:topbar) do %>
    <span class="topbar__title topbar__title--serif">Today</span>
    <span class="topbar__sub topbar__sub--serif">Set the day</span>
  <% end %>
<% end %>

<% if @step == 1 %>
  <div class="ritual-doc ritual-doc--sunrise"
       data-controller="ritual"
       data-ritual-sunrise-play-value="<%= @play_sunrise ? 'true' : 'false' %>">
    <%= render "morning_yesterday_review",
        wins: @yesterday_wins,
        tracked_min: @yesterday_tracked_min,
        scale_min: @yesterday_scale_min %>
  </div>
<% else %>
  <div class="ritual ritual--morning ritual--sunrise-step2" data-controller="ritual">
    <%= render "morning_step_2_plan_today" %>
  </div>
<% end %>
