<%# locals: (completed_tasks:, remaining_tasks:, actual_minutes:, planned_minutes:, donut_segments:) %>
<% today = current_user.today_in_zone %>
<% scale_min = [ planned_minutes, (current_user.work_hours_target * 60).to_i, 1 ].max %>
<% pct = [ (100.0 * actual_minutes / scale_min).round, 100 ].min %>
<% donut_style = sunset_donut_gradient(donut_segments) %>

<%= form_with url: ritual_evening_path, method: :post, data: { turbo_frame: "_top" }, html: { class: "ritual-doc__page" } do |f| %>
  <%= f.hidden_field :step, value: 1 %>

  <p class="ritual-doc__dateline"><%= today.strftime("%A, %B %-d") %></p>
  <h1 class="ritual-doc__title">The day, looking back.</h1>

  <p class="ritual-doc__prose">
    You tracked <strong><%= format_sunset_hm(actual_minutes) %></strong>
    of <%= format_sunset_hm(planned_minutes) %> planned.
    <% if completed_tasks.any? %>
      <%= pluralize(completed_tasks.size, "thing") %> marked complete.
    <% else %>
      Nothing marked complete today.
    <% end %>
  </p>

  <div class="ritual-doc__meter" aria-label="Time tracked today">
    <span>tracked</span>
    <strong><%= format_sunset_hours_badge(actual_minutes) %></strong>
    <span>of <%= format_sunset_hours_badge(planned_minutes) %></span>
    <span class="ritual-doc__meter-bar" role="presentation">
      <span class="ritual-doc__meter-fill" style="width: <%= pct %>%;"></span>
    </span>
  </div>

  <% if donut_style.present? %>
    <hr class="ritual-doc__divider" />
    <p class="ritual-doc__prompt">Where the hours went —</p>
    <ul class="ritual-doc__list">
      <% donut_segments.each do |seg| %>
        <li class="ritual-doc__list-item" style="cursor: default;">
          <span class="ritual-doc__list-mark" aria-hidden="true" style="background: <%= seg[:color] %>; border-radius: 50%; width: 14px; height: 14px; min-width: 14px;"></span>
          <span class="ritual-doc__list-main">
            <%= seg[:label] %>
            <span class="ritual-doc__list-meta">&middot; <%= format_sunset_hm(seg[:minutes]) %></span>
          </span>
        </li>
      <% end %>
    </ul>
  <% end %>

  <% if completed_tasks.any? %>
    <hr class="ritual-doc__divider" />
    <p class="ritual-doc__prompt">What you finished —</p>
    <ul class="ritual-doc__list">
      <% completed_tasks.each do |task| %>
        <li>
          <%= link_to task_assignment_path(task), class: "ritual-doc__list-item", data: { turbo_frame: "modal" } do %>
            <span class="ritual-doc__list-mark" aria-hidden="true">
              <%= render "stamps/#{current_user.stamp_choice || 'red_done'}" %>
            </span>
            <span class="ritual-doc__list-main">
              <%= task.title %>
              <span class="ritual-doc__list-meta">
                &middot; <%= format_sunset_hm(task.actual_duration_minutes.to_i) %> / <%= format_sunset_hm((task.planned_duration_minutes || 60).to_i) %>
                <% if task.project_name.present? %>&middot; <%= truncate(task.project_name, length: 22) %><% end %>
              </span>
            </span>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% end %>

  <% if remaining_tasks.any? %>
    <hr class="ritual-doc__divider" />
    <p class="ritual-doc__prompt">What stayed open —</p>
    <% remaining_tasks.each do |task| %>
      <div class="ritual-doc__card">
        <div class="ritual-doc__card-title"><%= task.title %></div>
        <div class="ritual-doc__card-meta">
          <%= format_sunset_hm((task.planned_duration_minutes || 60).to_i) %> planned
          <% if task.project_name.present? %>&middot; <%= truncate(task.project_name, length: 22) %><% end %>
        </div>
        <div class="ritual-doc__decisions" role="group" aria-label="What to do with <%= task.title %>">
          <label class="ritual-doc__decision">
            <input type="radio" name="tasks[<%= task.id %>]" value="tomorrow" checked>
            <span class="ritual-doc__decision-ui">tomorrow</span>
          </label>
          <label class="ritual-doc__decision">
            <input type="radio" name="tasks[<%= task.id %>]" value="sometime">
            <span class="ritual-doc__decision-ui">sometime</span>
          </label>
          <label class="ritual-doc__decision">
            <input type="radio" name="tasks[<%= task.id %>]" value="let_go">
            <span class="ritual-doc__decision-ui">let go</span>
          </label>
        </div>
      </div>
    <% end %>
  <% end %>

  <div class="ritual-doc__actions">
    <button type="submit" class="ritual-doc__link">continue <span aria-hidden="true">&rarr;</span></button>
  </div>

  <div class="ritual-doc__stepper" aria-hidden="true">
    <span class="ritual-doc__stepper-dot ritual-doc__stepper-dot--active"></span>
    <span class="ritual-doc__stepper-dot"></span>
  </div>
<% end %>
