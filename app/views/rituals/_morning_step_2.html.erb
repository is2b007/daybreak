<%# locals: (events:, assignments:) %>
<div class="ritual__step">
  <p class="ritual__prompt">Here's what's already scheduled.</p>

  <% if events.any? %>
    <div class="ritual__task-list mb-6">
      <% events.each do |event| %>
        <div class="ritual__task-item">
          <span class="text-xs text-muted"><%= event[:time] %></span>
          <span class="ritual__task-item__title"><%= event[:title] %></span>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-muted mb-6">No calendar events today. Wide open.</p>
  <% end %>

  <% if assignments.any? %>
    <p class="text-sm font-semibold mb-3">Basecamp assignments</p>
    <div class="ritual__task-list">
      <% assignments.each do |assignment| %>
        <div class="ritual__task-item">
          <span class="badge badge--basecamp"></span>
          <span class="ritual__task-item__title"><%= assignment[:title] %></span>
          <% if assignment[:due_on] %>
            <span class="text-xs text-muted">Due <%= assignment[:due_on] %></span>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <%= form_with url: ritual_morning_path, method: :post do |f| %>
    <%= f.hidden_field :step, value: 2 %>
    <div class="mt-8">
      <%= f.submit "Continue", class: "btn btn--primary btn--large" %>
    </div>
  <% end %>
</div>
