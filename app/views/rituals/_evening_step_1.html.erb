<%# locals: (tasks:) %>
<div class="ritual__step">
  <p class="ritual__prompt">What got done.</p>

  <% if tasks.any? %>
    <div class="ritual__task-list">
      <% tasks.each do |task| %>
        <div class="ritual__task-item" style="opacity: 0.8;">
          <div class="task-card__stamp" style="position: static; opacity: 0.85; transform: rotate(<%= task.stamp_rotation_degrees || 0 %>deg); width: 32px; height: 32px;">
            <%= render "stamps/#{current_user.stamp_choice}" %>
          </div>
          <span class="ritual__task-item__title" style="text-decoration: line-through; color: var(--color-text-muted);"><%= task.title %></span>
          <% if task.actual_duration_minutes.present? %>
            <span class="text-xs text-muted"><%= task.actual_duration_minutes %>m</span>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-muted">Nothing finished today. Some days are like that.</p>
  <% end %>

  <%= form_with url: ritual_evening_path, method: :post do |f| %>
    <%= f.hidden_field :step, value: 1 %>
    <div class="mt-8">
      <%= f.submit "Continue", class: "btn btn--primary btn--large" %>
    </div>
  <% end %>
</div>
