<% today = current_user.today_in_zone %>

<div class="ritual-doc__page">
  <p class="ritual-doc__dateline"><%= today.strftime("%A, %B %-d") %></p>
  <h1 class="ritual-doc__title">One line for tonight.</h1>

  <p class="ritual-doc__prose">What stays with you from today?</p>

  <%= form_with url: ritual_evening_path, method: :post, data: { turbo_frame: "_top" }, html: { class: "ritual-doc__reflection" } do |f| %>
    <%= f.hidden_field :step, value: 2 %>
    <%= f.text_area :reflection,
                    class: "ritual-doc__reflection-input",
                    placeholder: "Something worth remembering from today…",
                    rows: 3,
                    autofocus: true %>

    <p class="ritual-doc__reflection-hint">
      <% if current_user.hey_connected? %>
        Kept private &middot; synced to your HEY Journal.
      <% else %>
        Kept private on your own Daybreak.
      <% end %>
    </p>

    <div class="ritual-doc__actions">
      <%= link_to "back", ritual_evening_path(step: 1), class: "ritual-doc__link ritual-doc__link--back", data: { turbo_frame: "_top" } %>
      <button type="submit" class="btn btn--primary btn--large">Close the day</button>
    </div>
  <% end %>

  <div class="ritual-doc__stepper" aria-hidden="true">
    <span class="ritual-doc__stepper-dot"></span>
    <span class="ritual-doc__stepper-dot ritual-doc__stepper-dot--active"></span>
  </div>
</div>
