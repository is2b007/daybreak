<% content_for(:topbar) do %>
  <span class="topbar__title topbar__title--serif">Sundown</span>
  <span class="topbar__sub topbar__sub--serif">Wrapped for today</span>
<% end %>

<div class="ritual-doc ritual-doc--sunset ritual-doc--wrap"
     data-controller="ritual"
     data-ritual-sunset-play-value="<%= @play_sunset ? 'true' : 'false' %>"
     data-ritual-redirect-url-value="<%= root_path %>">
  <div class="ritual-doc__page">
    <h1 class="ritual-doc__wrap-title">The day is closed.</h1>
    <p class="ritual-doc__wrap-sub">Rest well. Tomorrow begins at sunrise.</p>
    <div class="ritual-doc__actions">
      <%= link_to "back to week", root_path, class: "ritual-doc__link ritual-doc__link--back" %>
    </div>
  </div>
</div>
