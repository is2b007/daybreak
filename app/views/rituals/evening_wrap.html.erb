<% content_for(:topbar) do %>
  <span class="topbar__title">Sundown</span>
  <span class="topbar__sub">Wrapped for today</span>
<% end %>

<div class="ritual ritual--evening ritual--evening-wrap"
     data-controller="ritual"
     data-ritual-sunset-play-value="true"
     data-ritual-redirect-url-value="<%= root_path %>">
  <div class="ritual__content ritual__content--sunset-wrap">
    <div class="sunset-wrap__icon" aria-hidden="true">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" style="opacity: 0.5;">
        <circle cx="12" cy="12" r="5"/>
        <line x1="12" y1="1" x2="12" y2="3"/>
        <line x1="12" y1="21" x2="12" y2="23"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="1" y1="12" x2="3" y2="12"/>
        <line x1="21" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
    </div>
    <h1 class="sunset-wrap__title">See you tomorrow.</h1>
    <p class="sunset-wrap__sub text-muted">Rest well.</p>
    <%= link_to "Back to week", root_path, class: "btn btn--ghost btn--small sunset-wrap__link" %>
  </div>
</div>
