<%# locals: (wins:, tracked_min:, scale_min:) %>
<% today = current_user.today_in_zone %>
<% yesterday = today - 1.day %>
<% pct = scale_min.positive? ? [ [ (100.0 * tracked_min / scale_min).round, 100 ].min, 0 ].max : 0 %>
<% target_h = (scale_min / 60.0).round(1) %>
<% tracked_label = format_sunrise_minutes(tracked_min) %>

<div class="ritual-doc__page">
  <p class="ritual-doc__dateline"><%= today.strftime("%A, %B %-d") %></p>
  <h1 class="ritual-doc__title"><%= current_user.time_of_day_greeting %>, <%= current_user.greeting_name %>.</h1>

  <p class="ritual-doc__prose">
    Yesterday —
    <em><%= yesterday.strftime("%A") %></em> —
    <% if wins.any? %>
      you finished
      <strong><%= pluralize(wins.size, "thing") %></strong>
      and tracked <strong><%= tracked_label %></strong> of <%= target_h == target_h.to_i ? target_h.to_i : target_h %> hours.
    <% else %>
      you didn&rsquo;t mark anything complete. That happens. Today is a fresh page.
    <% end %>
  </p>

  <% if wins.any? %>
    <hr class="ritual-doc__divider" />
    <p class="ritual-doc__prompt">What you finished —</p>

    <ul class="ritual-doc__list">
      <% wins.each do |task| %>
        <li>
          <%= link_to task_assignment_path(task), class: "ritual-doc__list-item", data: { turbo_frame: "modal" } do %>
            <span class="ritual-doc__list-mark" aria-hidden="true">
              <%= render "stamps/#{current_user.stamp_choice || 'red_done'}" %>
            </span>
            <span class="ritual-doc__list-main">
              <%= task.title %>
              <% if task.actual_duration_minutes.to_i.positive? %>
                <span class="ritual-doc__list-meta">&middot; <%= task.actual_duration_minutes %>m tracked<% if task.project_name.present? %> &middot; <%= truncate(task.project_name, length: 28) %><% end %></span>
              <% elsif task.project_name.present? %>
                <span class="ritual-doc__list-meta">&middot; <%= truncate(task.project_name, length: 28) %></span>
              <% end %>
            </span>
          <% end %>
        </li>
      <% end %>
    </ul>

    <div class="ritual-doc__meter" aria-label="Time tracked yesterday">
      <span>you tracked</span>
      <strong><%= tracked_label %></strong>
      <span>of <%= target_h == target_h.to_i ? target_h.to_i : target_h %> hr</span>
      <span class="ritual-doc__meter-bar" role="presentation">
        <span class="ritual-doc__meter-fill" style="width: <%= pct %>%;"></span>
      </span>
    </div>
  <% end %>

  <%= form_with url: ritual_morning_path, method: :post, data: { turbo_frame: "_top" }, html: { class: "ritual-doc__actions" } do |f| %>
    <%= f.hidden_field :step, value: 1 %>
    <button type="submit" class="btn btn--primary btn--large">Plan today</button>
  <% end %>

  <div class="ritual-doc__stepper" aria-hidden="true">
    <span class="ritual-doc__stepper-dot ritual-doc__stepper-dot--active"></span>
    <span class="ritual-doc__stepper-dot"></span>
  </div>
</div>
