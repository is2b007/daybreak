<%# locals: (wins:, tracked_min:, scale_min:) %>
<div class="sunrise-review">
  <div class="sunrise-review__intro">
    <h2 class="sunrise-review__title">Yesterday in review</h2>
    <p class="sunrise-review__subtitle text-muted">How you spent your time yesterday in total.</p>
  </div>

  <div class="sunrise-review__grid">
    <div class="sunrise-review__col sunrise-review__col--time">
      <h3 class="sunrise-review__label">Total time</h3>
      <% pct = scale_min.positive? ? [ [ (100.0 * tracked_min / scale_min).round, 100 ].min, 0 ].max : 0 %>
      <% bubble_left = [ [ pct, 6 ].max, 94 ].min %>
      <div class="sunrise-review__meter">
        <div class="sunrise-review__bubble" style="left: <%= bubble_left %>%"><%= format_sunrise_minutes(tracked_min) %></div>
        <div class="sunrise-review__track" role="presentation">
          <div class="sunrise-review__fill" style="width: <%= pct %>%;"></div>
        </div>
        <% target_h = scale_min / 60.0 %>
        <% mid_h = (target_h * 0.75).round(1) %>
        <div class="sunrise-review__ticks text-muted">
          <span>0</span>
          <span><%= mid_h == mid_h.to_i ? mid_h.to_i : mid_h %> hr</span>
          <span><%= target_h == target_h.to_i ? target_h.to_i : target_h %> hr</span>
        </div>
      </div>
      <p class="sunrise-review__tip text-muted text-xs">Tip: Open a task and use the timer; time rolls up here.</p>
    </div>

    <div class="sunrise-review__col sunrise-review__col--tasks">
      <h3 class="sunrise-review__label">Worked on</h3>
      <% if wins.any? %>
        <div class="sunrise-review__cards">
          <% wins.each do |task| %>
            <%= link_to task_assignment_path(task), class: "sunrise-review__card", data: { turbo_frame: "modal" } do %>
              <span class="sunrise-review__check" aria-hidden="true">✓</span>
              <div class="sunrise-review__card-main">
                <div class="sunrise-review__card-title"><%= task.title %></div>
                <div class="sunrise-review__card-meta text-muted text-xs">
                  <% if task.actual_duration_minutes.present? && task.actual_duration_minutes > 0 %>
                    <span><%= task.actual_duration_minutes %>m tracked</span>
                  <% else %>
                    <span>—</span>
                  <% end %>
                  <% if task.project_name.present? %>
                    <span class="sunrise-review__tag"># <%= truncate(task.project_name, length: 28) %></span>
                  <% end %>
                </div>
              </div>
              <% if task.source_badge_color %>
                <span class="badge badge--<%= task.source %>" title="<%= task.source.capitalize %>"></span>
              <% end %>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <p class="sunrise-review__empty text-muted text-sm">Nothing marked complete yesterday — that happens. Today is a fresh start.</p>
      <% end %>
    </div>
  </div>

  <%= form_with url: ritual_morning_path, method: :post, data: { turbo_frame: "_top" } do |f| %>
    <%= f.hidden_field :step, value: 1 %>
    <div class="sunrise-review__actions">
      <%= f.submit "Next", class: "btn btn--primary btn--large" %>
    </div>
  <% end %>
</div>
