  <%# HEY tab %>
  <div class="r-tab-content" id="rc-hey" data-right-panel-target="tab" data-tab="hey">
    <div class="r-head">
      <div class="r-dot r-dot--hey"></div>
      <div class="r-head-title">HEY</div>
      <div class="r-cnt" data-right-panel-target="heyCount"><%= @rp_hey_tasks&.count || 0 %></div>
    </div>
    <div class="r-list">
      <% if @rp_hey_tasks&.any? %>
        <% @rp_hey_tasks.each do |task| %>
          <div
            class="r-item"
            id="inbox_task_<%= task.id %>"
            draggable="true"
            data-task-id="<%= task.id %>"
            data-project-name=""
            data-planned-start="<%= task.planned_start_at&.iso8601 %>"
            data-created-at="<%= task.created_at&.iso8601 %>"
            data-title="<%= h(task.title) %>"
            data-action="dragstart->bc-inbox-panel#dragstart dragend->bc-inbox-panel#dragend">
            <div class="r-item__check">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.25"/>
              </svg>
            </div>
            <div class="r-item-body">
              <div class="r-item-name"><%= task.title %></div>
              <div class="r-item-project">HEY Email</div>
              <div class="r-item-drag-hint">
                <svg width="12" height="10" viewBox="0 0 12 10" fill="currentColor" aria-hidden="true">
                  <rect y="0" width="12" height="1.5" rx="0.75"/>
                  <rect y="4" width="12" height="1.5" rx="0.75"/>
                  <rect y="8" width="12" height="1.5" rx="0.75"/>
                </svg>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="r-empty">No HEY tasks</div>
      <% end %>
    </div>
  </div>

  <%# Daily log tab %>
  <div class="r-tab-content" id="rc-log" data-right-panel-target="tab" data-tab="log"
       data-controller="journal-editor"
       data-journal-editor-url-value="<%= journal_entry_path(Date.current) %>"
       data-journal-editor-csrf-value="<%= form_authenticity_token %>">
    <div class="jrnl-header">
      <span class="jrnl-date"><%= Date.current.strftime("%B %-d") %> <span class="jrnl-dow"><%= Date.current.strftime("%a") %></span></span>
      <span class="jrnl-status" data-journal-editor-target="status"></span>
    </div>
    <div class="jrnl-body"
         contenteditable="true"
         data-journal-editor-target="editor"
         data-action="input->journal-editor#onInput"
         data-placeholder="Add a note to your journal..."><%= sanitize(@rp_journal&.content.to_s) %></div>
    <div class="jrnl-toolbar">
      <button type="button" class="jrnl-btn" data-action="click->journal-editor#bold" title="Bold"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4h8a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/><path d="M6 12h9a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/></svg></button>
      <button type="button" class="jrnl-btn" data-action="click->journal-editor#italic" title="Italic"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="4" x2="10" y2="4"/><line x1="14" y1="20" x2="5" y2="20"/><line x1="15" y1="4" x2="9" y2="20"/></svg></button>
      <button type="button" class="jrnl-btn" data-action="click->journal-editor#strikethrough" title="Strikethrough"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><path d="M16 6C16 6 14.5 4 12 4C9 4 7 6 7 8C7 10 9 11 12 12"/><path d="M8 18C8 18 9.5 20 12 20C15 20 17 18 17 16C17 14 15 13 12 12"/></svg></button>
      <div class="jrnl-divider"></div>
      <button type="button" class="jrnl-btn" data-action="click->journal-editor#link" title="Link"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg></button>
      <div class="jrnl-divider"></div>
      <button type="button" class="jrnl-btn" data-action="click->journal-editor#heading" title="Heading"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12h16"/><path d="M4 18V6"/><path d="M20 18V6"/></svg></button>
      <button type="button" class="jrnl-btn" data-action="click->journal-editor#blockquote" title="Quote"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z"/><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"/></svg></button>
      <button type="button" class="jrnl-btn" data-action="click->journal-editor#code" title="Code"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg></button>
      <div class="jrnl-divider"></div>
      <button type="button" class="jrnl-btn" data-action="click->journal-editor#bulletList" title="Bullet list"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="9" y1="6" x2="20" y2="6"/><line x1="9" y1="12" x2="20" y2="12"/><line x1="9" y1="18" x2="20" y2="18"/><circle cx="4" cy="6" r="1.5" fill="currentColor" stroke="none"/><circle cx="4" cy="12" r="1.5" fill="currentColor" stroke="none"/><circle cx="4" cy="18" r="1.5" fill="currentColor" stroke="none"/></svg></button>
      <button type="button" class="jrnl-btn" data-action="click->journal-editor#orderedList" title="Numbered list"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="10" y1="6" x2="21" y2="6"/><line x1="10" y1="12" x2="21" y2="12"/><line x1="10" y1="18" x2="21" y2="18"/><path d="M4 6h1v4"/><path d="M4 10h2"/><path d="M6 18H4c0-1 2-2 2-3s-1-1.5-2-1.5"/></svg></button>
    </div>
  </div>

  <%# Goals tab %>
  <div class="r-tab-content" id="rc-goals" data-right-panel-target="tab" data-tab="goals">
    <div class="r-head">
      <div class="r-dot r-dot--amber"></div>
      <div class="r-head-title">Weekly goals</div>
    </div>
    <div class="g-list">
      <% if @rp_goals&.any? %>
        <div class="g-section-label"><%= Date.current.beginning_of_week(:monday).strftime("%B %-d") %> &ndash; <%= (Date.current.beginning_of_week(:monday) + 6.days).strftime("%-d, %Y") %></div>
        <% @rp_goals.each do |goal| %>
          <div class="g-card">
            <div class="g-title"><%= goal.title %></div>
            <div class="g-progress">
              <div class="g-progress-fill <%= 'g-progress-fill--complete' if goal.completed? %>" style="width: <%= goal.respond_to?(:progress_percent) ? goal.progress_percent : 0 %>%"></div>
            </div>
            <div class="g-meta">
              <span class="g-frac"><%= goal.progress_text %></span>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="r-empty">
          <%= link_to "Set weekly goals", weekly_checkin_path, style: "color: var(--amber); text-decoration: none;" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

