<div class="r-content">
  <%# Basecamp tab %>
  <div class="r-tab-content on" id="rc-bc" data-right-panel-target="tab" data-tab="bc">
    <div class="r-head">
      <div class="r-dot r-dot--bc"></div>
      <div class="r-head-title">Basecamp</div>
      <div class="r-cnt" data-right-panel-target="bcCount"><%= @rp_bc_tasks&.count || 0 %></div>
    </div>
    <div class="r-filter">
      <select class="r-select">
        <option>All projects</option>
      </select>
      <select class="r-sort">
        <option>Due date</option>
        <option>Project</option>
        <option>Size</option>
      </select>
    </div>
    <div class="r-list">
      <% if @rp_bc_tasks&.any? %>
        <% @rp_bc_tasks.each do |task| %>
          <div class="r-item" draggable="true">
            <div class="r-stripe r-stripe--bc"></div>
            <div class="r-item-body">
              <div class="r-item-name"><%= task.title %></div>
              <div class="r-item-meta">
                <span class="r-item-proj">BC<%= " \u00B7 #{task.project_name}" if task.project_name.present? %></span>
                <span class="r-item-size"><%= task.size.first.upcase %></span>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="r-empty">No Basecamp tasks</div>
      <% end %>
    </div>
  </div>

  <%# HEY tab %>
  <div class="r-tab-content" id="rc-hey" data-right-panel-target="tab" data-tab="hey">
    <div class="r-head">
      <div class="r-dot r-dot--hey"></div>
      <div class="r-head-title">HEY</div>
      <div class="r-cnt" data-right-panel-target="heyCount"><%= @rp_hey_tasks&.count || 0 %></div>
    </div>
    <div class="r-list">
      <% if @rp_hey_tasks&.any? %>
        <% @rp_hey_tasks.each do |task| %>
          <div class="r-item" draggable="true">
            <div class="r-stripe r-stripe--hey"></div>
            <div class="r-item-body">
              <div class="r-item-name"><%= task.title %></div>
              <div class="r-item-meta">
                <span class="r-item-proj">HEY<%= " \u00B7 #{task.project_name}" if task.project_name.present? %></span>
                <span class="r-item-size"><%= task.size.first.upcase %></span>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="r-empty">No HEY tasks</div>
      <% end %>
    </div>
  </div>

  <%# Goals tab %>
  <div class="r-tab-content" id="rc-goals" data-right-panel-target="tab" data-tab="goals">
    <div class="r-head">
      <div class="r-dot r-dot--amber"></div>
      <div class="r-head-title">Weekly goals</div>
    </div>
    <div class="g-list">
      <% if @rp_goals&.any? %>
        <div class="g-section-label"><%= Date.current.beginning_of_week(:monday).strftime("%B %-d") %> &ndash; <%= (Date.current.beginning_of_week(:monday) + 6.days).strftime("%-d, %Y") %></div>
        <% @rp_goals.each do |goal| %>
          <div class="g-card">
            <div class="g-title"><%= goal.title %></div>
            <div class="g-progress">
              <div class="g-progress-fill <%= 'g-progress-fill--complete' if goal.completed? %>" style="width: <%= goal.respond_to?(:progress_percent) ? goal.progress_percent : 0 %>%"></div>
            </div>
            <div class="g-meta">
              <span class="g-frac"><%= goal.progress_text %></span>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="r-empty">
          <%= link_to "Set weekly goals", weekly_checkin_path, style: "color: var(--amber); text-decoration: none;" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<%# Icon rail %>
<nav class="r-rail">
  <button class="rri on" data-action="click->right-panel#switchTab" data-tab="bc" data-right-panel-target="railBtn">
    <svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
    <span class="rri-tip">Basecamp</span>
  </button>
  <button class="rri" data-action="click->right-panel#switchTab" data-tab="hey" data-right-panel-target="railBtn">
    <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
    <span class="rri-tip">HEY</span>
  </button>
  <button class="rri" data-action="click->right-panel#switchTab" data-tab="goals" data-right-panel-target="railBtn">
    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/><circle cx="12" cy="12" r="1" style="fill:currentColor;stroke:none;"/></svg>
    <span class="rri-tip">Goals</span>
  </button>
</nav>
