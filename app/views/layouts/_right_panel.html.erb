<button type="button" class="right__resizer" data-action="pointerdown->right-panel#startResize" aria-label="Resize side panel" title="Drag to resize panel"></button>
<div class="r-content" data-right-panel-target="content">
  <%# Basecamp tab %>
  <div class="r-tab-content on" id="rc-bc" data-right-panel-target="tab" data-tab="bc" data-controller="bc-inbox-panel">
    <div class="r-head">
      <div class="r-dot r-dot--bc"></div>
      <div class="r-head-title">Basecamp</div>
      <div class="r-cnt" data-right-panel-target="bcCount" data-bc-inbox-panel-target="count"><%= @rp_bc_tasks&.count || 0 %></div>
    </div>
    <div class="r-filter">
      <select class="r-select" data-bc-inbox-panel-target="projectSelect" data-action="change->bc-inbox-panel#apply" aria-label="Filter by project">
        <option value="">All projects</option>
        <% (@rp_bc_project_names || []).each do |name| %>
          <option value="<%= h(name) %>"><%= h(name) %></option>
        <% end %>
        <% if @rp_bc_has_blank_project %>
          <option value="__empty__">(No project)</option>
        <% end %>
      </select>
      <select class="r-sort" data-bc-inbox-panel-target="sortSelect" data-action="change->bc-inbox-panel#apply" aria-label="Sort tasks">
        <option value="due_date">Due date</option>
        <option value="project">Project</option>
        <option value="size">Size</option>
      </select>
    </div>
    <div class="r-empty r-empty--filtered" hidden data-bc-inbox-panel-target="filteredEmpty">No tasks match this filter.</div>
    <div class="r-list" data-bc-inbox-panel-target="list">
      <% if @rp_bc_tasks&.any? %>
        <% @rp_bc_tasks.each do |task| %>
          <%
            pn = task.project_name.to_s.strip
            size_rank = task.read_attribute_before_type_cast(:size)
          %>
          <div
            class="r-item"
            draggable="true"
            data-bc-inbox-panel-target="item"
            data-project-name="<%= h(pn) %>"
            data-size-rank="<%= size_rank %>"
            data-planned-start="<%= task.planned_start_at&.iso8601 %>"
            data-created-at="<%= task.created_at&.iso8601 %>"
            data-title="<%= h(task.title) %>">
            <div class="r-stripe r-stripe--bc"></div>
            <div class="r-item-body">
              <div class="r-item-name"><%= task.title %></div>
              <div class="r-item-meta">
                <span class="r-item-proj">BC<%= " \u00B7 #{task.project_name}" if task.project_name.present? %></span>
                <span class="r-item-size"><%= task.size.to_s.first.upcase %></span>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="r-empty">No Basecamp tasks</div>
      <% end %>
    </div>
  </div>

  <%# HEY tab %>
  <div class="r-tab-content" id="rc-hey" data-right-panel-target="tab" data-tab="hey">
    <div class="r-head">
      <div class="r-dot r-dot--hey"></div>
      <div class="r-head-title">HEY</div>
      <div class="r-cnt" data-right-panel-target="heyCount"><%= @rp_hey_tasks&.count || 0 %></div>
    </div>
    <div class="r-list">
      <% if @rp_hey_tasks&.any? %>
        <% @rp_hey_tasks.each do |task| %>
          <div class="r-item" draggable="true">
            <div class="r-stripe r-stripe--hey"></div>
            <div class="r-item-body">
              <div class="r-item-name"><%= task.title %></div>
              <div class="r-item-meta">
                <span class="r-item-proj">HEY<%= " \u00B7 #{task.project_name}" if task.project_name.present? %></span>
                <span class="r-item-size"><%= task.size.first.upcase %></span>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="r-empty">No HEY tasks</div>
      <% end %>
    </div>
  </div>

  <%# Goals tab %>
  <div class="r-tab-content" id="rc-goals" data-right-panel-target="tab" data-tab="goals">
    <div class="r-head">
      <div class="r-dot r-dot--amber"></div>
      <div class="r-head-title">Weekly goals</div>
    </div>
    <div class="g-list">
      <% if @rp_goals&.any? %>
        <div class="g-section-label"><%= Date.current.beginning_of_week(:monday).strftime("%B %-d") %> &ndash; <%= (Date.current.beginning_of_week(:monday) + 6.days).strftime("%-d, %Y") %></div>
        <% @rp_goals.each do |goal| %>
          <div class="g-card">
            <div class="g-title"><%= goal.title %></div>
            <div class="g-progress">
              <div class="g-progress-fill <%= 'g-progress-fill--complete' if goal.completed? %>" style="width: <%= goal.respond_to?(:progress_percent) ? goal.progress_percent : 0 %>%"></div>
            </div>
            <div class="g-meta">
              <span class="g-frac"><%= goal.progress_text %></span>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="r-empty">
          <%= link_to "Set weekly goals", weekly_checkin_path, style: "color: var(--amber); text-decoration: none;" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

