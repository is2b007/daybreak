<!DOCTYPE html>
<html data-theme="<%= current_user&.theme || 'system' %>">
  <head>
    <title><%= content_for(:title) || "Daybreak" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Daybreak">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="app-layout">
    <% if logged_in? && current_user.onboarded? %>
      <nav class="nav">
        <div class="nav__brand">Daybreak</div>
        <div class="nav__center">
          <%= link_to "Week", root_path, class: "nav__link #{controller_name == 'weeks' ? 'nav__link--active' : ''}" %>
          <%= link_to "Today", day_path(Date.current), class: "nav__link #{controller_name == 'days' ? 'nav__link--active' : ''}" %>
        </div>
        <div class="nav__right">
          <%= link_to settings_path, class: "nav__icon-btn", title: "Settings" do %>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          <% end %>
          <%= button_to logout_path, method: :delete, class: "nav__icon-btn", title: "Sign out" do %>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          <% end %>
        </div>
      </nav>
    <% end %>

    <main class="app-main">
      <% if flash[:notice] %>
        <div class="container"><div class="flash flash--notice" data-controller="flash"><%= flash[:notice] %></div></div>
      <% end %>
      <% if flash[:alert] %>
        <div class="container"><div class="flash flash--alert" data-controller="flash"><%= flash[:alert] %></div></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
