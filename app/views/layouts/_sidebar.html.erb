<aside class="sb" data-controller="sidebar">
  <div class="sb-logo">
    <div class="sb-logo-text">
      <%= image_tag "daybreak-logo.svg", class: "sb-logo-mark", alt: "" %>
      <div class="sb-word">Daybreak</div>
    </div>
    <button type="button" class="sb-toggle" data-sidebar-target="toggleBtn" data-action="click->sidebar#toggle" aria-expanded="true" aria-label="Collapse sidebar" title="Collapse sidebar">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="19 7 13 12 19 17"/>
        <polyline points="13 7 7 12 13 17"/>
      </svg>
    </button>
  </div>

  <nav class="sb-nav">
    <%= link_to root_path, class: "sbi #{controller_name == 'weeks' ? 'on' : ''}", title: "Week (W)" do %>
      <%= render "icons/nav/week" %>
      <span class="sbi-label">Week</span>
      <kbd class="sbi-shortcut">W</kbd>
    <% end %>

    <%= link_to day_path(Date.current), class: "sbi #{controller_name == 'days' && @tab != 'log' ? 'on' : ''}", title: "Today (T)" do %>
      <%= render "icons/nav/today" %>
      <span class="sbi-label">Today</span>
      <kbd class="sbi-shortcut">T</kbd>
    <% end %>

    <%= link_to day_path(Date.current, tab: "log"), class: "sbi #{controller_name == 'daily_logs' || (controller_name == 'days' && @tab == 'log') ? 'on' : ''}", title: "Daily log" do %>
      <%= render "icons/nav/daily_log" %>
      <span class="sbi-label">Daily log</span>
    <% end %>

    <div class="sb-div"></div>
    <div class="sb-sect">Rituals</div>

    <%= link_to ritual_morning_path, class: "sbi #{controller_name == 'rituals' && action_name == 'morning' ? 'on' : ''}", title: "Sunrise (S)" do %>
      <%= render "icons/nav/sunrise" %>
      <span class="sbi-label">Sunrise</span>
      <kbd class="sbi-shortcut">S</kbd>
    <% end %>

    <%= link_to ritual_evening_path, class: "sbi #{controller_name == 'rituals' && action_name == 'evening' ? 'on' : ''}", title: "Sundown (D)" do %>
      <%= render "icons/nav/sunset" %>
      <span class="sbi-label">Sundown</span>
      <kbd class="sbi-shortcut">D</kbd>
    <% end %>
  </nav>

  <div class="sb-bot">
    <%# Do not use display:contents on the link — it breaks <img> painting in Safari/WebKit. %>
    <%= link_to settings_path, class: "sb-bot-link", title: "Settings" do %>
      <% if current_user.basecamp_avatar_url.present? %>
        <%= image_tag basecamp_avatar_path, alt: "", class: "sb-avatar sb-avatar--photo", size: "28x28", decoding: "async" %>
      <% else %>
        <div class="sb-avatar"><%= current_user.greeting_name.first.upcase %></div>
      <% end %>
      <div class="sb-username"><%= current_user.greeting_name %></div>
    <% end %>
    <div class="sb-badge">Pro</div>
  </div>
</aside>
