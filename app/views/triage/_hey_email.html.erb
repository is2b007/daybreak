<%# locals: (email:) %>
<div class="triage-row" id="hey_email_<%= email.id %>">
  <div class="triage-row__content">
    <div class="triage-row__meta">
      <span class="triage-row__sender"><%= email.sender_name.presence || email.sender_email.presence || "Unknown sender" %></span>
      <span class="triage-row__time"><%= time_ago_in_words(email.received_at) %> ago</span>
    </div>
    <% if email.hey_url.present? %>
      <%= link_to email.hey_url, target: "_blank", rel: "noopener", class: "triage-row__subject" do %>
        <%= truncate(email.subject, length: 120) %>
      <% end %>
    <% else %>
      <span class="triage-row__subject"><%= truncate(email.subject, length: 120) %></span>
    <% end %>
    <% if email.snippet.present? %>
      <p class="triage-row__snippet"><%= truncate(email.snippet, length: 140) %></p>
    <% end %>
  </div>
  <div class="triage-row__actions">
    <%= button_to "This week", triage_hey_email_path(email), method: :patch,
          form: { data: { turbo_stream: true } },
          class: "btn btn--primary btn--small" %>
    <%= button_to "Dismiss", dismiss_hey_email_path(email), method: :patch,
          form: { data: { turbo_stream: true } },
          class: "btn btn--ghost btn--small" %>
  </div>
</div>
