<h2 class="onboarding__title">Do you use HEY?</h2>
<p class="onboarding__subtitle">Connecting HEY unlocks your personal layer — calendar, to-dos, journal, and time tracking.</p>

<div class="hey-features">
  <div class="hey-feature">
    <svg class="hey-feature__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
    <span>HEY Calendar events appear alongside Basecamp schedules</span>
  </div>
  <div class="hey-feature">
    <svg class="hey-feature__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
    <span>Personal to-dos from HEY appear in your task list</span>
  </div>
  <div class="hey-feature">
    <svg class="hey-feature__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
    <span>Track time with HEY's built-in time tracker</span>
  </div>
  <div class="hey-feature">
    <svg class="hey-feature__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
    <span>Daily log and reflections sync to your HEY Journal</span>
  </div>
</div>

<%= form_with url: onboarding_path, method: :patch do |f| %>
  <%= f.hidden_field :step, value: 3 %>
  <div class="flex flex-col gap-3">
    <% if HeyClient.configured? %>
      <% if current_user.hey_connected? %>
        <div class="text-center mb-2">
          <span class="settings__connection-status settings__connection-status--connected"></span>
          <span class="text-sm text-muted">HEY connected</span>
        </div>
        <%= f.submit "Continue", name: "connect_hey", value: "true", class: "btn btn--primary btn--large" %>
      <% else %>
        <%= link_to "Connect HEY", auth_hey_path, class: "btn btn--primary btn--large" %>
        <%= f.submit "Skip for now", name: "connect_hey", value: "false", class: "btn btn--ghost btn--large" %>
      <% end %>
    <% else %>
      <%= f.submit "Skip for now", name: "connect_hey", value: "false", class: "btn btn--primary btn--large" %>
      <p class="text-xs text-muted text-center">HEY support is on the way. You'll be able to connect from Settings.</p>
    <% end %>
  </div>
<% end %>

<p class="text-xs text-muted mt-4 text-center">
  Without HEY, everything still works — timer, journal, and personal tasks are stored locally in Daybreak. You can connect HEY anytime from Settings.
</p>
