<%# locals: (event:) %>
<% chip_payload = { id: event[:id], source: event[:source].to_s, all_day: event[:all_day], starts_at_iso: event[:starts_at_iso], ends_at_iso: event[:ends_at_iso] }.compact.to_json %>
<div class="calendar-event calendar-event--<%= event[:source] || 'basecamp' %><%= ' calendar-event--all-day' if event[:all_day] %><%= ' calendar-event--colored' if event[:color].present? %>"
     draggable="true"
     data-controller="calendar-event-chip"
     data-calendar-event-chip-payload-value="<%= ERB::Util.html_escape(chip_payload) %>"
     <% if event[:color].present? %>style="--event-color: <%= event[:color] %>"<% end %>>
  <span class="calendar-event__time"><%= event[:time] %></span>
  <span class="calendar-event__title"><%= event[:title] %></span>
</div>
