<% content_for(:topbar) do %>
  <div class="week-nav">
    <div class="week-nav__arrows">
      <%= link_to week_path(@window_start - 4.days), class: "topbar__nav-arrow", title: "Previous 4 days" do %>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      <% end %>
    </div>
    <span class="topbar__title"><%= @window_start.strftime("%b %-d") %> &ndash; <%= @window_end.strftime("%b %-d") %></span>
    <div class="week-nav__arrows">
      <%= link_to week_path(@window_start + 4.days), class: "topbar__nav-arrow", title: "Next 4 days" do %>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      <% end %>
    </div>
    <span class="topbar__sub"><%= @window_start.strftime("%Y") %></span>
  </div>
<% end %>

<% first_run = @task_assignments.empty? && @weekly_goals.empty? && current_user.day_plans.where.not(morning_ritual_done: false).none? %>

<div class="week-view" data-controller="sortable">
  <% if first_run %>
    <div class="first-run">
      <h2 class="first-run__heading">Welcome, <%= current_user.greeting_name %>.</h2>
      <p class="first-run__body">
        This is your week. The columns below are days &mdash; your Basecamp to-dos are syncing in
        quietly as we speak, and they&rsquo;ll show up in the inbox on the right. When you&rsquo;re ready,
        <%= link_to "open sunrise", ritual_morning_path %> to shape today.
      </p>
    </div>
  <% end %>

  <div class="kanban">
    <% @window_dates.each do |date| %>
      <%= render "day_column", date: date, tasks: @tasks_by_day[date] || [], events: @calendar_events[date] || [] %>
    <% end %>
  </div>

  <%= render "sometime_row", tasks: @sometime_tasks %>
</div>
