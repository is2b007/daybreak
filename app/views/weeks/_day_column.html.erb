<% pending_count = tasks.count { |t| !t.completed? } %>
<%= turbo_frame_tag "day_#{date}" do %>
  <div class="kanban__column <%= 'kanban__column--today' if date == Date.current %> <%= 'kanban__column--week-start' if date.monday? %>"
       data-sortable-target="column"
       data-date="<%= date %>">

    <div class="kanban__column-header <%= 'kanban__column-header--today' if date == Date.current %>">
      <div class="kanban__header-pill" aria-label="<%= date.strftime('%A') %>, <%= pending_count %> tasks">
        <span><%= date.strftime("%a") %></span>
        <% if pending_count.positive? %>
          <span class="kanban__header-pill-count"><%= pending_count %></span>
        <% end %>
      </div>
      <% if date == Date.current %>
        <div class="kanban__day-date kanban__day-date--today">
          <%= link_to day_path(date), class: "kanban__day-date-link", data: { turbo_frame: "_top" } do %>
            <span class="kanban__day-month"><%= date.strftime("%b") %></span>
            <span class="kanban__day-number" aria-label="<%= date.strftime('%B %-d') %>"><%= date.day %></span>
          <% end %>
        </div>
      <% else %>
        <div class="kanban__day-date">
          <%= link_to date.strftime("%b %-d"), day_path(date), style: "color: inherit; text-decoration: none;", data: { turbo_frame: "_top" } %>
        </div>
      <% end %>
    </div>

    <% if events.any? %>
      <div class="kanban__events">
        <% events.each do |event| %>
          <%= render "calendar_event", event: event %>
        <% end %>
      </div>
    <% end %>

    <div id="day_pending_list_<%= date %>" class="kanban__tasks" data-sortable-target="taskList" data-date="<%= date %>">
      <% pending = tasks.reject(&:completed?) %>
      <% if pending.empty? %>
        <div id="kanban_empty_<%= date %>" class="kanban__empty">
          <% if date == Date.current && events.empty? %>
            <%= link_to "Plan today", ritual_morning_path, class: "btn btn--pill btn--small kanban__empty-link", data: { turbo_frame: "_top" } %>
          <% elsif date < Date.current %>
            <span class="kanban__empty-text">&mdash;</span>
          <% else %>
            <span class="kanban__empty-text kanban__drop-hint">Drop something here</span>
          <% end %>
        </div>
      <% else %>
        <% pending.sort_by(&:position).each do |task| %>
          <%= render "shared/task_card", task: task, compact: true %>
        <% end %>
      <% end %>
    </div>

    <%= form_with url: task_assignments_path, method: :post, class: "kanban__quick-add" do |f| %>
      <%= hidden_field_tag :date, date.to_s %>
      <%= hidden_field_tag :size, "medium" %>
      <%= f.text_field :title, name: :title, class: "kanban__quick-add-input", placeholder: "Add task", required: true, autocomplete: "off" %>
      <%= f.submit "+", class: "btn btn--icon btn--secondary kanban__quick-add-button", aria: { label: "Add local task" }, title: "Add local task" %>
    <% end %>

    <div class="kanban__tasks kanban__tasks--completed" id="day_<%= date %>_completed">
      <% tasks.select(&:completed?).each do |task| %>
        <%= render "shared/task_card", task: task, compact: true %>
      <% end %>
    </div>
  </div>
<% end %>
