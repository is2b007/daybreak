<%# locals: (task:, active_timer: nil, any_running_timer: nil) %>
<div class="focus-overlay" data-controller="focus" data-action="keydown@document->focus#keydown">
  <div class="focus">
    <div class="focus__topbar">
      <div class="focus__modes">
        <span class="focus__mode focus__mode--active">Focus</span>
      </div>
      <button type="button" class="focus__close" data-action="click->focus#close" aria-label="Close (Escape)">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <div class="focus__body">
      <div class="focus__main">
        <div class="focus__task-row">
          <div class="focus__check <%= 'focus__check--done' if task.completed? %>">
            <% if task.completed? %>
              <svg width="24" height="24" viewBox="0 0 20 20" fill="none"><rect x="1" y="1" width="18" height="18" rx="4.5" fill="#16A34A"/><polyline points="5.5,10.5 8.5,13.5 14.5,7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
            <% else %>
              <svg width="24" height="24" viewBox="0 0 20 20" fill="none"><rect x="1" y="1" width="18" height="18" rx="4.5" stroke="currentColor" stroke-width="1.5"/></svg>
            <% end %>
          </div>
          <h1 class="focus__title"><%= task.title %></h1>
        </div>

        <div class="focus__timer-section">
          <div class="focus__timer-labels">
            <div class="focus__timer-col">
              <span class="focus__timer-label">ACTUAL</span>
              <% if active_timer %>
                <span class="focus__timer-value" data-controller="timer" data-timer-started-at-value="<%= active_timer.started_at.iso8601 %>">
                  <span data-timer-target="display">0:00:00</span>
                </span>
              <% else %>
                <span class="focus__timer-value"><%= format_focus_duration(task.actual_duration_minutes || 0) %></span>
              <% end %>
            </div>
            <div class="focus__timer-col">
              <span class="focus__timer-label">PLANNED</span>
              <span class="focus__timer-value"><%= format_focus_duration(task.planned_duration_minutes || 0) %></span>
            </div>
          </div>

          <div class="focus__timer-controls">
            <% if active_timer %>
              <%= button_to timer_session_path(active_timer), method: :patch,
                    class: "focus__timer-btn focus__timer-btn--stop" do %>
                <span class="focus__timer-btn-icon">&#9632;</span> STOP
              <% end %>
            <% elsif any_running_timer %>
              <div class="focus__timer-hint">Timer running on another task</div>
            <% else %>
              <%= button_to timer_sessions_path, params: { task_assignment_id: task.id },
                    class: "focus__timer-btn focus__timer-btn--start" do %>
                <span class="focus__timer-btn-icon">&#9654;</span> START
              <% end %>
            <% end %>
          </div>
        </div>

        <div class="focus__notes">
          <%= form_with model: task,
                data: { controller: "auto-save", turbo: true, turbo_stream: true } do |f| %>
            <%= f.text_area :description,
                  class: "focus__notes-input",
                  placeholder: "Notes...",
                  rows: 6,
                  data: { action: "input->auto-save#save" } %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
